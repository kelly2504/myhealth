<VBox prefHeight="450.0" prefWidth="544.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <MenuBar fx:id="menu" prefHeight="25.0" prefWidth="870.0" VBox.vgrow="NEVER">
      <menus>
            <Menu mnemonicParsing="false" text="Home">
               <items>
                <MenuItem fx:id="homepage" mnemonicParsing="false" text="Go to Homepage" />
               </items></Menu>
            <Menu fx:id="profile" mnemonicParsing="false" text="Profile">
              <items>
                  <MenuItem fx:id="viewProfile" mnemonicParsing="false" text="View my profile" />
                  <MenuItem fx:id="updateProfile" mnemonicParsing="false" text="Update my profile" />
              </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Exit">
               <items>
                  <MenuItem fx:id="homepage1" mnemonicParsing="false" text="Exit and log out" />
               </items>
            </Menu>
      </menus>
    </MenuBar>
    	<!--<fx:include source="MenuBar.fxml">-->
      <FlowPane prefHeight="63.0" prefWidth="544.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="MyHealth" wrappingWidth="153.96875">
               <font>
                  <Font name="Serif Regular" size="36.0" />
               </font>
               <FlowPane.margin>
                  <Insets left="20.0" top="12.0" />
               </FlowPane.margin>
            </Text>
