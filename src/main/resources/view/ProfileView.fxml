                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </GridPane.margin>
                     <font>
                        <Font name="Serif Regular" size="14.0" />
                     </font>
                  </Label>
                  <Label prefHeight="17.0" prefWidth="271.0" text="First name:" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </GridPane.margin>
                     <font>
                        <Font name="Serif Regular" size="14.0" />
                     </font>
                  </Label>
                  <Label prefHeight="17.0" prefWidth="259.0" text="Last name:" GridPane.columnIndex="1" GridPane.rowIndex="2">
                     <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </GridPane.margin>
                     <font>
                        <Font name="Serif Regular" size="14.0" />
                     </font>
                  </Label>
                  <Text fx:id="username" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" GridPane.columnIndex="2">
                     <font>
                        <Font name="Serif Regular" size="14.0" />
                     </font></Text>
                  <Text fx:id="firstname" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" GridPane.columnIndex="2" GridPane.rowIndex="1">
                     <font>
                        <Font name="Serif Regular" size="14.0" />
                     </font></Text>
                  <Text fx:id="lastname" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" GridPane.columnIndex="2" GridPane.rowIndex="2">
