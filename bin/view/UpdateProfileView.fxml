            <Insets right="30.0" />
         </opaqueInsets>
      </TextField>
      <Label prefHeight="17.0" prefWidth="120.0" text="Change your details" textAlignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS">
         <opaqueInsets>
            <Insets top="30.0" />
