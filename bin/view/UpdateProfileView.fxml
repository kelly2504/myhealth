<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane prefHeight="284.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" maxWidth="300.0" minWidth="10.0" prefWidth="148.5" />
    <ColumnConstraints hgrow="SOMETIMES" maxWidth="433.5" minWidth="10.0" prefWidth="351.5" />
  </columnConstraints>
  <rowConstraints>
      <RowConstraints maxHeight="40.5" minHeight="10.0" prefHeight="40.5" vgrow="SOMETIMES" />
    <RowConstraints maxHeight="46.0" minHeight="10.0" prefHeight="33.0" vgrow="SOMETIMES" />
    <RowConstraints maxHeight="53.5" minHeight="10.0" prefHeight="39.0" vgrow="SOMETIMES" />
    <RowConstraints maxHeight="59.5" minHeight="10.0" prefHeight="39.5" vgrow="SOMETIMES" />
      <RowConstraints maxHeight="59.5" minHeight="10.0" prefHeight="32.0" vgrow="SOMETIMES" />
      <RowConstraints maxHeight="63.5" minHeight="10.0" prefHeight="34.5" vgrow="SOMETIMES" />
      <RowConstraints maxHeight="52.5" minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
  </rowConstraints>
   <children>
      <Text fx:id="username" strokeType="OUTSIDE" strokeWidth="0.0" text="Username" GridPane.rowIndex="1">
         <GridPane.margin>
            <Insets bottom="5.0" top="5.0" />
         </GridPane.margin>
         <font>
            <Font name="Serif Regular" size="13.0" />
         </font>
      </Text>
      <Label fx:id="first" prefHeight="17.0" prefWidth="169.0" text="Firstname" GridPane.rowIndex="2">
         <GridPane.margin>
            <Insets bottom="5.0" top="5.0" />
         </GridPane.margin>
         <font>
            <Font name="Serif Regular" size="13.0" />
         </font>
      </Label>
      <TextField fx:id="firstname" prefHeight="25.0" prefWidth="406.0" promptText="Enter firstname" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
         <opaqueInsets>
            <Insets right="30.0" />
         </opaqueInsets>
         <GridPane.margin>
            <Insets />
         </GridPane.margin>
      </TextField>
      <Label fx:id="last" prefHeight="17.0" prefWidth="165.0" text="Lastname" GridPane.rowIndex="3">
         <GridPane.margin>
            <Insets bottom="5.0" top="5.0" />
         </GridPane.margin>
         <font>
            <Font name="Serif Regular" size="13.0" />
         </font>
      </Label>
      <TextField fx:id="lastname" promptText="Enter lastname" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.hgrow="ALWAYS" GridPane.rowIndex="3" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
